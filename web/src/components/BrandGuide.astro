---
import { renderBrandGuideHtml } from '../lib/brandGuide.js';
import type { ResolvedBrand } from '../lib/encyclopedia.js';

export interface Props {
  brand: ResolvedBrand;
}

const { brand } = Astro.props;
const html = renderBrandGuideHtml(brand);
---

<section class="section brand-guide-section" data-component="brand-guide">
  <h2>Brand Guide</h2>
  <p class="section-lede">
    Inline rendering of the Markdown brand guide. Same source as the
    <code>markdown/brand-guide.md</code> download.
  </p>
  <div class="brand-guide-body" set:html={html}></div>
</section>

<style>
  .brand-guide-section {
    padding: 24px 0 32px;
  }
  .brand-guide-section > h2 {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .brand-guide-body {
    background: var(--surface);
    border-radius: 14px;
    padding: 24px 28px;
    color: var(--text-primary);
    font-size: 14px;
    line-height: 1.6;
  }
  /* Heading scale steps down one level relative to the page so the
     embedded guide reads as a sub-document rather than the page itself. */
  .brand-guide-body :global(h1) {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .brand-guide-body :global(h2) {
    font-size: 18px;
    font-weight: 700;
    margin: 24px 0 8px;
    color: var(--text-primary);
  }
  .brand-guide-body :global(h3) {
    font-size: 15px;
    font-weight: 600;
    margin: 18px 0 6px;
    color: var(--text-secondary);
  }
  .brand-guide-body :global(h4) {
    font-size: 13px;
    font-weight: 600;
    margin: 14px 0 4px;
    color: var(--text-secondary);
    font-family: var(--font-mono);
  }
  .brand-guide-body :global(p) {
    margin: 0 0 12px;
  }
  .brand-guide-body :global(blockquote) {
    margin: 12px 0;
    padding: 8px 14px;
    border-left: 3px solid var(--surface-elevated);
    color: var(--text-secondary);
    font-size: 13px;
  }
  .brand-guide-body :global(blockquote p) {
    margin: 0;
  }
  .brand-guide-body :global(code) {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--bg);
    padding: 1px 6px;
    border-radius: 3px;
    color: var(--primary);
  }
  .brand-guide-body :global(pre) {
    background: var(--bg);
    padding: 12px 14px;
    border-radius: 8px;
    overflow-x: auto;
  }
  .brand-guide-body :global(pre code) {
    background: transparent;
    padding: 0;
    color: var(--text-primary);
  }
  .brand-guide-body :global(ul),
  .brand-guide-body :global(ol) {
    margin: 0 0 12px;
    padding-left: 22px;
  }
  .brand-guide-body :global(li) {
    margin-bottom: 4px;
  }
  .brand-guide-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 12px 0;
    font-size: 13px;
  }
  .brand-guide-body :global(thead) {
    background: var(--surface-elevated);
  }
  .brand-guide-body :global(th),
  .brand-guide-body :global(td) {
    text-align: left;
    padding: 8px 10px;
    border-bottom: 1px solid var(--surface-elevated);
  }
  .brand-guide-body :global(th) {
    font-weight: 600;
    font-size: 12px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .brand-guide-body :global(td code) {
    background: var(--bg);
  }
  .brand-guide-body :global(hr) {
    border: none;
    border-top: 1px solid var(--surface-elevated);
    margin: 24px 0;
  }
  .brand-guide-body :global(a) {
    color: var(--primary);
    text-decoration: none;
  }
  .brand-guide-body :global(a:hover) {
    text-decoration: underline;
  }
</style>
