---
import { brandTheme, getResolvedBrandBySlug } from '../lib/encyclopedia.js';

export interface Props {
  title: string;
  description?: string;
  section?: 'home' | 'brands' | 'palettes' | 'fonts' | 'builder' | 'install' | 'how-to-use' | 'request';
}

const { title, description, section = 'home' } = Astro.props;

const navItems = [
  { id: 'home', label: 'Home', href: '/' },
  { id: 'brands', label: 'Brands', href: '/brands' },
  { id: 'palettes', label: 'Palettes', href: '/palettes' },
  { id: 'fonts', label: 'Fonts', href: '/fonts' },
  { id: 'builder', label: 'Builder', href: '/builder' },
  { id: 'install', label: 'Install', href: '/install' },
  { id: 'how-to-use', label: 'How to use', href: '/how-to-use' },
  { id: 'request', label: 'Request a brand', href: '/request-brand' },
] as const;

// The site IS the Convergent Systems brand. Drive every CSS variable from
// the resolved convergent-systems@latest spec — light and dark mode both —
// so a change to brands/convergent-systems/*/brand.yaml or to
// palettes/convergent-deep-space/*/atom.yaml flows through here without a
// second source of truth.
const csBrand = getResolvedBrandBySlug('convergent-systems');
const findSwatch = (id: string): string | null => {
  if (!csBrand) return null;
  const sw = csBrand.palette.data.swatches.find((s) => s.id === id);
  return sw?.value ?? null;
};
const csLight = csBrand?.palette.data.modes.light.roles ?? {};
const csDark = csBrand?.palette.data.modes.dark.roles ?? {};
const swatch = (mode: Record<string, string>, role: string, fallback: string): string => {
  const id = mode[role];
  if (!id) return fallback;
  return findSwatch(id) ?? fallback;
};
const csTheme = csBrand ? brandTheme(csBrand) : null;

const lightVars = {
  bg: swatch(csLight, 'background', '#F9F7F0'),
  surface: swatch(csLight, 'surface', '#FDFCF7'),
  surfaceElevated: swatch(csLight, 'surface-elevated', '#FFFFFF'),
  textPrimary: swatch(csLight, 'text-primary', '#07090F'),
  textSecondary: swatch(csLight, 'text-secondary', '#11182C'),
  textTertiary: swatch(csLight, 'text-tertiary', '#7D8699'),
  primary: swatch(csLight, 'primary', '#5CD6FF'),
  primaryHover: swatch(csLight, 'primary-hover', '#8DE4FF'),
  accent: swatch(csLight, 'accent', '#F4C75E'),
  accentHover: swatch(csLight, 'accent-hover', '#FFD982'),
  warning: swatch(csLight, 'warning', '#FF8A3D'),
  warningHover: swatch(csLight, 'warning-hover', '#FFB070'),
};

const darkVars = {
  bg: swatch(csDark, 'background', '#07090F'),
  surface: swatch(csDark, 'surface', '#0B1020'),
  surfaceElevated: swatch(csDark, 'surface-elevated', '#11182C'),
  textPrimary: swatch(csDark, 'text-primary', '#EEF1F7'),
  textSecondary: swatch(csDark, 'text-secondary', '#A4ADBF'),
  textTertiary: swatch(csDark, 'text-tertiary', '#7D8699'),
  primary: swatch(csDark, 'primary', '#5CD6FF'),
  primaryHover: swatch(csDark, 'primary-hover', '#8DE4FF'),
  accent: swatch(csDark, 'accent', '#F4C75E'),
  accentHover: swatch(csDark, 'accent-hover', '#FFD982'),
  warning: swatch(csDark, 'warning', '#FF8A3D'),
  warningHover: swatch(csDark, 'warning-hover', '#FFB070'),
};

// The four mark dots are the brand's signature accent quartet.
const markColors = {
  d1: findSwatch('frost-cyan') ?? '#5CD6FF',
  d2: findSwatch('solar-gold') ?? '#F4C75E',
  d3: findSwatch('ember-orange') ?? '#FF8A3D',
  d4: findSwatch('snow-0') ?? '#EEF1F7',
};

const fontSans = csTheme?.headingFont ?? "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fira+Code:wght@400;500;700&family=JetBrains+Mono:wght@400;500;700&family=Cascadia+Code:wght@400;500;700&family=Lato:wght@400;700;900&family=Raleway:wght@400;600;700;900&family=Lora:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/hack-font@3.3.0/build/web/hack.css" />
    <link rel="ai-index" href="/ai/index.json" type="application/json" />
  </head>

  <body>
    <div class="shell">
      <main class="content">
        <slot />
        <footer class="footer">
          <p>
            Open source ·
            <a href="https://github.com/convergent-systems-co/branding-library">github.com/convergent-systems-co/branding-library</a>
          </p>
          <p class="micro">A Convergent Systems project · Built on Astro, deployed on Cloudflare Pages</p>
          <p class="micro">AI agents: machine-readable catalog and usage instructions at <a href="/ai/index.json">/ai/index.json</a></p>
        </footer>
      </main>

      <aside class="sidenav">
        <a class="brand" href="/">
          <span class="mark" aria-hidden="true">
            <span class="dot dot-1"></span>
            <span class="dot dot-2"></span>
            <span class="dot dot-3"></span>
            <span class="dot dot-4"></span>
          </span>
          <span class="brand-text">Brand<br/>Atoms</span>
        </a>

        <nav class="nav">
          <ul>
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={['nav-link', { active: item.id === section }]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="aside-meta">
          <a href="https://github.com/convergent-systems-co/branding-library" class="meta-link">
            <span>↗</span> GitHub
          </a>
        </div>
      </aside>
    </div>

    <style is:global define:vars={{
      lightBg: lightVars.bg,
      lightSurface: lightVars.surface,
      lightSurfaceElevated: lightVars.surfaceElevated,
      lightTextPrimary: lightVars.textPrimary,
      lightTextSecondary: lightVars.textSecondary,
      lightTextTertiary: lightVars.textTertiary,
      lightPrimary: lightVars.primary,
      lightPrimaryHover: lightVars.primaryHover,
      lightAccent: lightVars.accent,
      lightAccentHover: lightVars.accentHover,
      lightWarning: lightVars.warning,
      darkBg: darkVars.bg,
      darkSurface: darkVars.surface,
      darkSurfaceElevated: darkVars.surfaceElevated,
      darkTextPrimary: darkVars.textPrimary,
      darkTextSecondary: darkVars.textSecondary,
      darkTextTertiary: darkVars.textTertiary,
      darkPrimary: darkVars.primary,
      darkPrimaryHover: darkVars.primaryHover,
      darkAccent: darkVars.accent,
      darkAccentHover: darkVars.accentHover,
      darkWarning: darkVars.warning,
      brandDot1: markColors.d1,
      brandDot2: markColors.d2,
      brandDot3: markColors.d3,
      brandDot4: markColors.d4,
      brandFontSans: fontSans,
    }}>
      :root {
        --bg: var(--lightBg);
        --surface: var(--lightSurface);
        --surface-elevated: var(--lightSurfaceElevated);
        --text-primary: var(--lightTextPrimary);
        --text-secondary: var(--lightTextSecondary);
        --text-tertiary: var(--lightTextTertiary);
        --primary: var(--lightPrimary);
        --primary-hover: var(--lightPrimaryHover);
        --accent: var(--lightAccent);
        --accent-hover: var(--lightAccentHover);
        --warning: var(--lightWarning);
        --success: var(--lightAccent);

        --font-sans: var(--brandFontSans);
        --font-mono: 'JetBrains Mono', 'Fira Code', Menlo, Monaco, monospace;

        --sidenav-width: 220px;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: var(--darkBg);
          --surface: var(--darkSurface);
          --surface-elevated: var(--darkSurfaceElevated);
          --text-primary: var(--darkTextPrimary);
          --text-secondary: var(--darkTextSecondary);
          --text-tertiary: var(--darkTextTertiary);
          --primary: var(--darkPrimary);
          --primary-hover: var(--darkPrimaryHover);
          --accent: var(--darkAccent);
          --accent-hover: var(--darkAccentHover);
          --warning: var(--darkWarning);
        }
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--text-primary);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .shell {
        display: grid;
        grid-template-columns: 1fr var(--sidenav-width);
        min-height: 100vh;
        max-width: 1320px;
        margin: 0 auto;
      }

      .content {
        min-width: 0;
        padding: 32px 32px 0 32px;
      }

      .sidenav {
        position: sticky;
        top: 0;
        height: 100vh;
        padding: 32px 24px;
        border-left: 1px solid var(--surface);
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: var(--text-primary);
      }
      .mark {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 3px;
        width: 32px;
        height: 32px;
        padding: 4px;
        background: var(--surface);
        border-radius: 8px;
        flex-shrink: 0;
      }
      .dot {
        width: 100%;
        height: 100%;
        border-radius: 50%;
      }
      .dot-1 { background: var(--brandDot1); }
      .dot-2 { background: var(--brandDot2); }
      .dot-3 { background: var(--brandDot3); }
      .dot-4 { background: var(--brandDot4); }
      .brand-text {
        font-weight: 800;
        font-size: 17px;
        line-height: 1.05;
        letter-spacing: -0.02em;
      }

      .nav ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 4px;
      }
      .nav-link {
        display: block;
        padding: 8px 12px;
        text-decoration: none;
        color: var(--text-secondary);
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
        transition: background 0.12s ease, color 0.12s ease;
      }
      .nav-link:hover {
        background: var(--surface);
        color: var(--text-primary);
      }
      .nav-link.active {
        background: var(--surface);
        color: var(--primary);
        font-weight: 600;
      }

      .aside-meta {
        margin-top: auto;
        padding-top: 16px;
        border-top: 1px solid var(--surface);
      }
      .meta-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
        color: var(--text-tertiary);
        font-family: var(--font-mono);
        font-size: 12px;
      }
      .meta-link:hover { color: var(--primary); }

      .footer {
        margin-top: 96px;
        padding: 32px 0 64px;
        text-align: left;
        border-top: 1px solid var(--surface);
        color: var(--text-secondary);
        font-size: 14px;
      }
      .footer a {
        color: var(--primary);
        text-decoration: none;
        font-family: var(--font-mono);
      }
      .footer a:hover { text-decoration: underline; }
      .footer .micro {
        font-size: 12px;
        color: var(--text-tertiary);
        margin-top: 8px;
      }

      @media (max-width: 880px) {
        .shell {
          grid-template-columns: 1fr;
        }
        .sidenav {
          position: static;
          height: auto;
          border-left: none;
          border-bottom: 1px solid var(--surface);
          flex-direction: row;
          align-items: center;
          padding: 16px 24px;
          gap: 24px;
        }
        .nav ul {
          flex-direction: row;
          flex-wrap: wrap;
        }
        .aside-meta {
          margin-top: 0;
          padding-top: 0;
          border-top: none;
        }
        .content {
          padding: 16px 24px 0 24px;
        }
      }
    </style>
  </body>
</html>
