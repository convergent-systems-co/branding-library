---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import Layout from '../../layouts/Layout.astro';
import BrandGuide from '../../components/BrandGuide.astro';
import DownloadsSection from '../../components/DownloadsSection.astro';
import { brandTheme, fontShowcaseFamily, getBrands, getResolvedBrandBySlug } from '../../lib/encyclopedia.js';

export function getStaticPaths() {
  const seen = new Set<string>();
  return getBrands()
    .filter((b) => {
      if (seen.has(b.slug)) return false;
      seen.add(b.slug);
      return true;
    })
    .map((b) => ({ params: { slug: b.slug } }));
}

const { slug } = Astro.params;
const brand = getResolvedBrandBySlug(slug!);
if (!brand) {
  return Astro.redirect('/brands');
}

const repoRoot = resolve(
  process.cwd(),
  process.cwd().endsWith('/web') ? '..' : '.',
);

const readAssetSvg = (file: string): string | null => {
  if (!file.toLowerCase().endsWith('.svg')) return null;
  try {
    const full = resolve(repoRoot, 'brands', brand.id, brand.version, file);
    return readFileSync(full, 'utf8');
  } catch {
    return null;
  }
};

const findSwatch = (id: string) =>
  brand.palette.data.swatches.find((s) => s.id === id);

const lightRoles = Object.entries(brand.palette.data.modes.light.roles).sort(([a], [b]) => a.localeCompare(b));
const darkRoles = Object.entries(brand.palette.data.modes.dark.roles).sort(([a], [b]) => a.localeCompare(b));

const brandColorRoles = brand.roles?.colors ? Object.entries(brand.roles.colors).sort(([a], [b]) => a.localeCompare(b)) : [];
const brandTypeRoles = brand.roles?.typography ? Object.entries(brand.roles.typography).sort(([a], [b]) => a.localeCompare(b)) : [];

const rulesBySeverity = {
  error: brand.rules.filter((r) => r.severity === 'error'),
  warning: brand.rules.filter((r) => r.severity === 'warning'),
  recommendation: brand.rules.filter((r) => r.severity === 'recommendation'),
};

const severityColor = {
  error: 'var(--warning)',
  warning: 'var(--accent)',
  recommendation: 'var(--primary)',
};

const fontShowcase = (roleKey: string): string => {
  const font = brand.fonts.find((f) => f.role === roleKey);
  return font ? fontShowcaseFamily(font.slug) : 'var(--font-sans)';
};

const ruleDetails = (rule: typeof brand.rules[number]): { key: string; value: string }[] => {
  const out: { key: string; value: string }[] = [];
  if ('min' in rule && rule.min !== undefined) out.push({ key: 'min', value: String(rule.min) });
  if ('max' in rule && rule.max !== undefined) out.push({ key: 'max', value: String(rule.max) });
  if ('unit' in rule && rule.unit) out.push({ key: 'unit', value: rule.unit });
  if ('against' in rule && rule.against) out.push({ key: 'against', value: rule.against });
  if ('minRatio' in rule && rule.minRatio !== undefined) out.push({ key: 'minRatio', value: String(rule.minRatio) });
  if ('standard' in rule && rule.standard) out.push({ key: 'standard', value: rule.standard });
  if ('use' in rule && rule.use) out.push({ key: 'use', value: rule.use });
  if ('treatments' in rule && rule.treatments) out.push({ key: 'treatments', value: rule.treatments.join(', ') });
  if ('allowed' in rule && rule.allowed) out.push({ key: 'allowed', value: rule.allowed.join(', ') });
  if ('forbidden' in rule && rule.forbidden) out.push({ key: 'forbidden', value: rule.forbidden.join(', ') });
  if ('pairsWith' in rule && rule.pairsWith) out.push({ key: 'pairsWith', value: rule.pairsWith.join(', ') });
  if ('doesNotPairWith' in rule && rule.doesNotPairWith) out.push({ key: 'doesNotPairWith', value: rule.doesNotPairWith.join(', ') });
  if ('forbiddenContexts' in rule && rule.forbiddenContexts) out.push({ key: 'forbiddenContexts', value: rule.forbiddenContexts.join(', ') });
  if ('allowedContexts' in rule && rule.allowedContexts) out.push({ key: 'allowedContexts', value: rule.allowedContexts.join(', ') });
  if ('requires' in rule && rule.requires) out.push({ key: 'requires', value: rule.requires });
  if ('minSizeRatio' in rule && rule.minSizeRatio !== undefined) out.push({ key: 'minSizeRatio', value: String(rule.minSizeRatio) });
  if ('criterion' in rule && rule.criterion) out.push({ key: 'criterion', value: rule.criterion });
  if (rule.when) {
    out.push({ key: 'when', value: Object.entries(rule.when).map(([k, v]) => `${k}=${JSON.stringify(v)}`).join(', ') });
  }
  if (rule.appliesIn) {
    out.push({ key: 'appliesIn', value: rule.appliesIn.join(', ') });
  }
  return out;
};

const pangram = 'The quick brown fox jumps over 13 lazy dogs.';

const theme = brandTheme(brand);
const themeStyle = `
  --b-primary: ${theme.primary};
  --b-primary-hover: ${theme.primaryHover};
  --b-surface: ${theme.surface};
  --b-surface-elevated: ${theme.surfaceElevated};
  --b-background: ${theme.background};
  --b-text: ${theme.textPrimary};
  --b-text-secondary: ${theme.textSecondary};
  --b-text-tertiary: ${theme.textTertiary};
  --b-accent: ${theme.accent};
  --b-highlight: ${theme.highlight};
  --b-warning: ${theme.warning};
  --b-error: ${theme.error};
  --b-success: ${theme.success};
  --b-on-primary: ${theme.onPrimary};
  --b-identity: ${theme.identity};
  --b-on-identity: ${theme.onIdentity};
  --b-heading-font: ${theme.headingFont};
  --b-body-font: ${theme.bodyFont};
`;
---

<Layout
  title={`${brand.name} — BRAND-Atoms`}
  description={brand.description ?? ''}
  section="brands"
>
  <nav class="crumb">
    <a href="/brands">← Brands</a>
    <span>·</span>
    <code>{brand.id}@{brand.version}</code>
  </nav>

  <header class="detail-hero" style={themeStyle}>
    <h1>{brand.name}</h1>
    {brand.description && <p class="lede">{brand.description}</p>}
    <div class="stats-inline">
      <span><strong>1</strong> palette</span>
      <span><strong>{brand.fonts.length}</strong> font{brand.fonts.length === 1 ? '' : 's'}</span>
      <span><strong>{brand.assets.length}</strong> asset{brand.assets.length === 1 ? '' : 's'}</span>
      <span><strong>{brand.rules.length}</strong> rule{brand.rules.length === 1 ? '' : 's'}</span>
      {brand.tags && brand.tags.length > 0 && (
        <span class="tags">{brand.tags.map((t) => <code class="tag">{t}</code>)}</span>
      )}
    </div>

    <div class="ai-prompt" data-brand-slug={brand.id} data-brand-version={brand.version}>
      <button type="button" class="ai-prompt-btn" data-action="copy-prompt">
        <span class="copy-icon" aria-hidden="true">⧉</span>
        <span class="copy-label">Copy AI prompt</span>
      </button>
      <details class="ai-prompt-preview">
        <summary>Preview prompt</summary>
        <pre><code>{`Use the ${brand.id}@${brand.version} brand from brand-atoms.com.
Fetch https://brand-atoms.com/dist/brands/${brand.id}/${brand.version}/json/brand.json
and apply its role mappings (primary, accent, identity, etc.),
reference the fonts in references.fonts, and honor every rule where
severity is "error". Surface any deviation you choose to make.`}</code></pre>
      </details>
    </div>
  </header>

  <script is:inline>
    (() => {
      const root = document.querySelector('.ai-prompt');
      if (!root) return;
      const btn = root.querySelector('[data-action="copy-prompt"]');
      const label = btn?.querySelector('.copy-label');
      if (!btn || !label) return;
      const slug = root.getAttribute('data-brand-slug');
      const version = root.getAttribute('data-brand-version');
      const prompt = `Use the ${slug}@${version} brand from brand-atoms.com.\nFetch https://brand-atoms.com/dist/brands/${slug}/${version}/json/brand.json\nand apply its role mappings (primary, accent, identity, etc.),\nreference the fonts in references.fonts, and honor every rule where\nseverity is "error". Surface any deviation you choose to make.`;
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(prompt);
          const original = label.textContent;
          label.textContent = 'Copied — paste into Claude/GPT';
          btn.classList.add('copied');
          setTimeout(() => {
            label.textContent = original;
            btn.classList.remove('copied');
          }, 2400);
        } catch {
          label.textContent = 'Copy failed — see preview';
        }
      });
    })();
  </script>

  <DownloadsSection brand={brand} />

  <BrandGuide brand={brand} />

  <section class="section components-section">
    <h2>Components <span class="section-aside">— same template, themed by {brand.name}</span></h2>
    <p class="section-lede">
      Every block below renders from the resolved palette + font references on this brand.
      Swap the brand and the same template re-themes — no per-brand component code required.
    </p>

    <div class="brand-canvas" style={themeStyle}>
      <div class="canvas-row canvas-row-type">
        <h3 class="canvas-h1">{brand.name}</h3>
        <h4 class="canvas-h2">A clear hierarchy in {brand.name}'s typeface</h4>
        <h5 class="canvas-h3">Tertiary heading — supporting structure</h5>
        <p class="canvas-body">
          Body copy renders in the brand's prose font on the brand's background.
          Inline <a class="canvas-link" href="#">links</a> and{' '}
          <span class="canvas-highlight">highlighted phrases</span> pick up
          the brand's primary and highlight roles. Code spans like{' '}
          <code class="canvas-code">brand.references.palette</code>{' '}
          fall back to the monospace face.
        </p>
        <blockquote class="canvas-quote">
          A blockquote uses the brand's accent color as its rule.
          Useful for pulling tagline copy out of running prose.
        </blockquote>
      </div>

      <div class="canvas-row canvas-row-grid">
        <div class="canvas-col">
          <h6 class="canvas-h6">Bulleted list</h6>
          <ul class="canvas-list">
            <li>Bullet markers inherit the brand's primary color.</li>
            <li>Item spacing reads as a deliberate vertical rhythm.</li>
            <li>Nested items still resolve to the same primary.
              <ul>
                <li>Second-level item using the accent.</li>
                <li>Third bullet wraps cleanly at narrow widths.</li>
              </ul>
            </li>
          </ul>
        </div>

        <div class="canvas-col">
          <h6 class="canvas-h6">Numbered list</h6>
          <ol class="canvas-list canvas-list-ordered">
            <li>Open the brand's resolved spec.</li>
            <li>Apply roles to the component template.</li>
            <li>Render the surface in the brand's identity.</li>
            <li>Audit the output against the typed rules.</li>
          </ol>
        </div>
      </div>

      <div class="canvas-row canvas-row-buttons">
        <h6 class="canvas-h6">Buttons</h6>
        <div class="canvas-buttons">
          <button class="canvas-btn canvas-btn-primary" type="button">Primary action</button>
          <button class="canvas-btn canvas-btn-secondary" type="button">Secondary</button>
          <button class="canvas-btn canvas-btn-ghost" type="button">Ghost</button>
        </div>
      </div>

      <div class="canvas-row canvas-row-callouts">
        <h6 class="canvas-h6">Callout boxes</h6>

        <div class="callout callout-info">
          <div class="callout-icon" aria-hidden="true">i</div>
          <div class="callout-body">
            <strong class="callout-title">Info</strong>
            <p>Neutral status — provides supplemental context without urgency. Uses the brand's primary as the rule.</p>
          </div>
        </div>

        <div class="callout callout-success">
          <div class="callout-icon" aria-hidden="true">✓</div>
          <div class="callout-body">
            <strong class="callout-title">Success</strong>
            <p>Confirms a completed action — palette role <code>success</code> determines the rule color.</p>
          </div>
        </div>

        <div class="callout callout-warning">
          <div class="callout-icon" aria-hidden="true">!</div>
          <div class="callout-body">
            <strong class="callout-title">Warning</strong>
            <p>Calls out something that needs attention but isn't an error — palette role <code>warning</code>.</p>
          </div>
        </div>

        <div class="callout callout-error">
          <div class="callout-icon" aria-hidden="true">×</div>
          <div class="callout-body">
            <strong class="callout-title">Error</strong>
            <p>Surfaces a failure that blocks progress — palette role <code>error</code>. Use sparingly.</p>
          </div>
        </div>
      </div>

      <div class="canvas-row canvas-row-table">
        <h6 class="canvas-h6">Table</h6>
        <table class="canvas-table">
          <thead>
            <tr>
              <th>Role</th>
              <th>Resolves to</th>
              <th>Mode</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>primary</td><td>brand color #1</td><td>light + dark</td></tr>
            <tr><td>accent</td><td>brand color #2</td><td>light + dark</td></tr>
            <tr><td>warning</td><td>brand warning</td><td>light + dark</td></tr>
            <tr><td>error</td><td>brand error</td><td>light + dark</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Atoms</h2>
    <div class="atoms-grid">
      <a class="atom-card" href={`/palettes/${brand.palette.slug}`}>
        <div class="atom-kind">palette</div>
        <div class="atom-name">{brand.palette.data.name}</div>
        <div class="atom-ref"><code>{brand.palette.slug}@{brand.palette.resolvedVersion}</code></div>
        <div class="swatch-strip">
          {brand.palette.data.swatches.slice(0, 14).map((s) => (
            <span class="swatch" style={`background:${s.value}`} title={`${s.id} ${s.value}`}></span>
          ))}
        </div>
      </a>

      {brand.fonts.map((f) => (
        <a class="atom-card" href={`/fonts/${f.slug}`} style={`--font-showcase:${fontShowcaseFamily(f.slug)}`}>
          <div class="atom-kind">font · {f.role}</div>
          <div class="atom-name font-rendered">{f.data.name}</div>
          <div class="atom-ref"><code>{f.slug}@{f.resolvedVersion}</code></div>
          <div class="font-rendered sample">{pangram}</div>
        </a>
      ))}
    </div>
  </section>

  {(brandColorRoles.length > 0 || brandTypeRoles.length > 0) && (
    <section class="section">
      <h2>Brand semantic roles</h2>
      <p class="section-lede">Brand-level role overrides on top of palette-default mappings. Each role resolves to a concrete swatch or font reference.</p>

      <div class="roles-grid">
        {brandColorRoles.length > 0 && (
          <div class="role-panel">
            <h3>Colors</h3>
            <div class="role-list">
              {brandColorRoles.map(([role, swatchId]) => {
                const sw = findSwatch(swatchId);
                return (
                  <div class="role-row">
                    <span class="role-chip" style={`background:${sw?.value ?? '#888'}`}></span>
                    <span class="role-name">{role}</span>
                    <code class="role-arrow">→ {swatchId}</code>
                    {sw && <code class="role-hex">{sw.value}</code>}
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {brandTypeRoles.length > 0 && (
          <div class="role-panel">
            <h3>Typography</h3>
            <div class="role-list">
              {brandTypeRoles.map(([role, fontKey]) => {
                const font = brand.fonts.find((f) => f.role === fontKey);
                return (
                  <div class="role-row type-row" style={`--font-showcase:${font ? fontShowcaseFamily(font.slug) : 'var(--font-sans)'}`}>
                    <span class="role-name">{role}</span>
                    <code class="role-arrow">→ {fontKey}</code>
                    {font && <span class="role-fontname font-rendered">{font.data.name}</span>}
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <section class="section">
    <h2>Palette mode mappings <span class="section-aside">(from {brand.palette.slug})</span></h2>
    <div class="modes-grid">
      <div class="mode-panel">
        <h3>Light mode <span class="mode-count">({lightRoles.length} roles)</span></h3>
        <div class="role-list">
          {lightRoles.map(([role, swatchId]) => {
            const sw = findSwatch(swatchId);
            return (
              <div class="role-row">
                <span class="role-chip" style={`background:${sw?.value ?? '#888'}`}></span>
                <span class="role-name">{role}</span>
                <code class="role-arrow">→ {swatchId}</code>
              </div>
            );
          })}
        </div>
      </div>
      <div class="mode-panel">
        <h3>Dark mode <span class="mode-count">({darkRoles.length} roles)</span></h3>
        <div class="role-list">
          {darkRoles.map(([role, swatchId]) => {
            const sw = findSwatch(swatchId);
            return (
              <div class="role-row">
                <span class="role-chip" style={`background:${sw?.value ?? '#888'}`}></span>
                <span class="role-name">{role}</span>
                <code class="role-arrow">→ {swatchId}</code>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  {brand.assets.length > 0 && (
    <section class="section">
      <h2>Assets</h2>
      <div class="assets-grid">
        {brand.assets.map((asset) => (
          <div class="asset-card">
            <header class="asset-head">
              <h3>{asset.name}</h3>
              <span class="asset-category">{asset.category}</span>
            </header>
            {asset.description && <p class="asset-desc">{asset.description}</p>}
            <div class="asset-variants">
              {asset.variants.map((variant) => {
                const svg = readAssetSvg(variant.file);
                return (
                  <div class={`asset-preview asset-${variant.intendedMode ?? 'any'}`}>
                    {svg ? (
                      <div class="asset-render" set:html={svg}></div>
                    ) : (
                      <div class="asset-fallback"><code>{variant.file}</code></div>
                    )}
                    <div class="asset-variant-meta">
                      <code>{variant.id}</code>
                      {variant.colorScheme && <span> · {variant.colorScheme}</span>}
                      {variant.intendedMode && <span> · {variant.intendedMode}</span>}
                      {variant.dimensions?.width && variant.dimensions?.height && (
                        <span> · {variant.dimensions.width}×{variant.dimensions.height}</span>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {brand.rules.length > 0 && (
    <section class="section">
      <h2>Rules <span class="section-aside">({brand.rules.length} typed constraints)</span></h2>

      {(['error', 'warning', 'recommendation'] as const).map((severity) => {
        const list = rulesBySeverity[severity];
        if (list.length === 0) return null;
        return (
          <div class="rule-group">
            <h3 class="rule-group-head">
              <span class="severity-badge" style={`background:${severityColor[severity]}`}></span>
              {severity} · {list.length} rule{list.length === 1 ? '' : 's'}
            </h3>
            <div class="rule-list">
              {list.map((rule) => (
                <article class="rule-card">
                  <header class="rule-head">
                    <code class="rule-type">{rule.type}</code>
                    <code class="rule-target">{rule.target}</code>
                  </header>
                  <div class="rule-details">
                    {ruleDetails(rule).map((d) => (
                      <div class="rule-detail">
                        <code class="rule-key">{d.key}</code>
                        <code class="rule-value">{d.value}</code>
                      </div>
                    ))}
                  </div>
                  {rule.rationale && <p class="rule-rationale">{rule.rationale}</p>}
                </article>
              ))}
            </div>
          </div>
        );
      })}
    </section>
  )}

  {brand.provenance && (
    <section class="section">
      <h2>Provenance</h2>
      <dl class="provenance">
        {brand.provenance.source && (
          <>
            <dt>Source</dt>
            <dd><a href={brand.provenance.source}>{brand.provenance.source}</a></dd>
          </>
        )}
        <dt>License</dt>
        <dd><code>{brand.provenance.license}</code></dd>
        {brand.provenance.attribution && (
          <>
            <dt>Attribution</dt>
            <dd>{brand.provenance.attribution}</dd>
          </>
        )}
        {brand.provenance.importedDate && (
          <>
            <dt>Imported</dt>
            <dd><code>{brand.provenance.importedDate}</code></dd>
          </>
        )}
        {brand.provenance.notes && (
          <>
            <dt>Notes</dt>
            <dd>{brand.provenance.notes}</dd>
          </>
        )}
      </dl>
    </section>
  )}

  <style>
    .crumb {
      padding: 16px 0 0;
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--text-tertiary);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .crumb a { color: var(--text-secondary); text-decoration: none; }
    .crumb a:hover { color: var(--primary); }

    .detail-hero {
      background: var(--b-identity);
      color: var(--b-on-identity);
      padding: 40px 36px 36px;
      border: 2px solid var(--b-accent);
      border-radius: 16px;
      margin: 16px 0 24px;
      font-family: var(--b-body-font);
    }
    .detail-hero h1 {
      font-family: var(--b-heading-font);
      font-size: 56px;
      font-weight: 800;
      letter-spacing: -0.03em;
      margin: 0 0 12px;
      line-height: 1;
      color: var(--b-on-identity);
    }
    .lede {
      font-size: 17px;
      color: var(--b-on-identity);
      opacity: 0.82;
      max-width: 760px;
      margin: 0 0 20px;
    }
    .stats-inline {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
      font-size: 14px;
      color: var(--b-on-identity);
      opacity: 0.78;
      font-family: var(--font-mono);
    }
    .stats-inline strong { color: var(--b-on-identity); font-weight: 700; opacity: 1; }
    .tags { display: inline-flex; gap: 6px; flex-wrap: wrap; }
    .tag {
      background: color-mix(in srgb, var(--b-on-identity) 12%, transparent);
      color: var(--b-on-identity);
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 12px;
    }

    .ai-prompt {
      margin-top: 22px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      align-items: flex-start;
    }
    .ai-prompt-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: color-mix(in srgb, var(--b-on-identity) 18%, transparent);
      color: var(--b-on-identity);
      border: 1px solid color-mix(in srgb, var(--b-on-identity) 28%, transparent);
      padding: 9px 14px;
      border-radius: 8px;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.12s ease, border-color 0.12s ease, color 0.12s ease;
    }
    .ai-prompt-btn:hover {
      background: color-mix(in srgb, var(--b-on-identity) 28%, transparent);
      border-color: color-mix(in srgb, var(--b-on-identity) 50%, transparent);
    }
    .ai-prompt-btn.copied {
      background: var(--b-accent);
      color: var(--b-identity);
      border-color: var(--b-accent);
    }
    .copy-icon { font-size: 14px; line-height: 1; }
    .ai-prompt-preview {
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--b-on-identity);
      opacity: 0.75;
