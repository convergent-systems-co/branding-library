---
const palettes = [
  { id: 'nord', name: 'Nord', swatchCount: 16, license: 'MIT', swatches: ['#2E3440', '#88C0D0', '#5E81AC', '#A3BE8C', '#EBCB8B', '#BF616A', '#B48EAD', '#ECEFF4'] },
  { id: 'material-2', name: 'Material 2', swatchCount: 251, license: 'Apache-2.0', swatches: ['#F44336', '#E91E63', '#9C27B0', '#3F51B5', '#2196F3', '#009688', '#4CAF50', '#FF9800'] },
  { id: 'material-3', name: 'Material 3', swatchCount: 78, license: 'Apache-2.0', swatches: ['#6750A4', '#625B71', '#7D5260', '#B3261E', '#79747E', '#D0BCFF', '#CCC2DC', '#EFB8C8'] },
];

const fonts = [
  { id: 'inter', name: 'Inter', kind: 'sans-serif', license: 'OFL-1.1' },
  { id: 'firacode-nerdfont', name: 'FiraCode Nerd Font', kind: 'monospace', license: 'OFL-1.1' },
  { id: 'jetbrainsmono-nerdfont', name: 'JetBrainsMono Nerd Font', kind: 'monospace', license: 'OFL-1.1' },
  { id: 'hack-nerdfont', name: 'Hack Nerd Font', kind: 'monospace', license: 'MIT' },
  { id: 'cascadiacode-nerdfont', name: 'CascadiaCode Nerd Font', kind: 'monospace', license: 'OFL-1.1' },
];

const stats = {
  palettes: palettes.length,
  swatches: palettes.reduce((s, p) => s + p.swatchCount, 0),
  fonts: fonts.length,
  brands: 1,
  constraintTypes: 11,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Brand Atoms — civilization-grade encyclopedia of branding</title>
    <meta name="description" content="A machine-readable, version-controlled encyclopedia of palettes, fonts, and brand standards. Consumed by AIs and humans to produce on-brand outputs." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />
  </head>

  <body>
    <header class="hero">
      <div class="mark" aria-hidden="true">
        <div class="dot dot-1"></div>
        <div class="dot dot-2"></div>
        <div class="dot dot-3"></div>
        <div class="dot dot-4"></div>
      </div>
      <h1>Brand Atoms</h1>
      <p class="tagline">
        A machine-readable encyclopedia of palettes, fonts, and brand standards —
        the canonical source AIs and humans consume to produce on-brand outputs.
      </p>
      <p class="status">
        <span class="status-dot"></span>
        Encyclopedia is alive · Builder UI coming · Phase 3.5 in flight
      </p>
    </header>

    <section class="stats">
      <div class="stat">
        <div class="stat-value">{stats.palettes}</div>
        <div class="stat-label">palettes</div>
      </div>
      <div class="stat">
        <div class="stat-value">{stats.swatches}</div>
        <div class="stat-label">swatches</div>
      </div>
      <div class="stat">
        <div class="stat-value">{stats.fonts}</div>
        <div class="stat-label">fonts</div>
      </div>
      <div class="stat">
        <div class="stat-value">{stats.constraintTypes}</div>
        <div class="stat-label">constraint types</div>
      </div>
    </section>

    <section class="catalog">
      <h2>Palettes</h2>
      <div class="palette-grid">
        {palettes.map((p) => (
          <article class="palette-card">
            <header>
              <h3>{p.name}</h3>
              <span class="meta">{p.swatchCount} swatches · {p.license}</span>
            </header>
            <div class="swatch-row">
              {p.swatches.map((hex) => (
                <span class="swatch" style={`background:${hex}`} title={hex}></span>
              ))}
            </div>
            <code class="ref">{p.id}@1.0.0</code>
          </article>
        ))}
      </div>

      <h2>Fonts</h2>
      <ul class="font-list">
        {fonts.map((f) => (
          <li class={`font-card font-${f.kind}`}>
            <div class="font-name">{f.name}</div>
            <div class="font-meta">{f.kind} · {f.license}</div>
            <code class="ref">{f.id}@1.0.0</code>
          </li>
        ))}
      </ul>
    </section>

    <footer>
      <p>
        Open source ·
        <a href="https://github.com/convergent-systems-co/branding-library">github.com/convergent-systems-co/branding-library</a>
      </p>
      <p class="micro">A Convergent Systems project · Built on Astro, deployed on Cloudflare Pages</p>
    </footer>

    <style is:global>
      :root {
        /* Nord palette */
        --nord0: #2E3440;
        --nord1: #3B4252;
        --nord2: #434C5E;
        --nord3: #4C566A;
        --nord4: #D8DEE9;
        --nord5: #E5E9F0;
        --nord6: #ECEFF4;
        --nord7: #8FBCBB;
        --nord8: #88C0D0;
        --nord9: #81A1C1;
        --nord10: #5E81AC;
        --nord11: #BF616A;
        --nord12: #D08770;
        --nord13: #EBCB8B;
        --nord14: #A3BE8C;
        --nord15: #B48EAD;

        /* Semantic roles (light mode) */
        --bg: var(--nord6);
        --surface: var(--nord5);
        --surface-elevated: var(--nord4);
        --text-primary: var(--nord0);
        --text-secondary: var(--nord1);
        --text-tertiary: var(--nord3);
        --primary: var(--nord10);
        --accent: var(--nord8);
        --success: var(--nord14);

        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', Menlo, Monaco, monospace;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: var(--nord0);
          --surface: var(--nord1);
          --surface-elevated: var(--nord2);
          --text-primary: var(--nord6);
          --text-secondary: var(--nord4);
          --text-tertiary: var(--nord3);
          --primary: var(--nord8);
        }
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--text-primary);
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .hero {
        max-width: 720px;
        margin: 0 auto;
        padding: 96px 24px 48px;
        text-align: center;
      }
      .mark {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 6px;
        width: 56px;
        height: 56px;
        margin: 0 auto 32px;
        padding: 8px;
        background: var(--surface);
        border-radius: 12px;
      }
      .dot {
        width: 100%;
        height: 100%;
        border-radius: 50%;
      }
      .dot-1 { background: var(--nord8); }
      .dot-2 { background: var(--nord14); }
      .dot-3 { background: var(--nord13); }
      .dot-4 { background: var(--nord15); }
      .hero h1 {
        font-size: 56px;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin: 0 0 16px;
        line-height: 1.05;
      }
      .tagline {
        font-size: 18px;
        color: var(--text-secondary);
        max-width: 560px;
        margin: 0 auto 32px;
        line-height: 1.6;
      }
      .status {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-family: var(--font-mono);
        color: var(--text-tertiary);
        background: var(--surface);
        padding: 8px 16px;
        border-radius: 999px;
        margin: 0;
      }
      .status-dot {
        width: 8px;
        height: 8px;
        background: var(--success);
        border-radius: 50%;
        animation: pulse 2s ease-in-out infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 16px;
        max-width: 720px;
        margin: 0 auto 96px;
        padding: 0 24px;
      }
      .stat {
        background: var(--surface);
        border-radius: 12px;
        padding: 24px 16px;
        text-align: center;
      }
      .stat-value {
        font-size: 36px;
        font-weight: 700;
        color: var(--primary);
        line-height: 1;
        margin-bottom: 8px;
      }
      .stat-label {
        font-size: 13px;
        color: var(--text-secondary);
        font-family: var(--font-mono);
        text-transform: lowercase;
      }

      .catalog {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 24px 96px;
      }
      .catalog h2 {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 24px;
      }
      .catalog h2:not(:first-child) { margin-top: 64px; }

      .palette-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 16px;
      }
      .palette-card {
        background: var(--surface);
        border-radius: 16px;
        padding: 20px;
      }
      .palette-card header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 16px;
      }
      .palette-card h3 {
        font-size: 18px;
        font-weight: 600;
        margin: 0;
      }
      .meta {
        font-size: 12px;
        font-family: var(--font-mono);
        color: var(--text-tertiary);
      }
      .swatch-row {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: 4px;
        margin-bottom: 12px;
      }
      .swatch {
        aspect-ratio: 1;
        border-radius: 6px;
      }
      .ref {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--text-tertiary);
        display: block;
      }

      .font-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 12px;
      }
      .font-card {
        background: var(--surface);
        border-radius: 12px;
        padding: 16px 20px;
      }
      .font-name {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 4px;
      }
      .font-monospace .font-name { font-family: var(--font-mono); font-weight: 500; }
      .font-meta {
        font-size: 12px;
        font-family: var(--font-mono);
        color: var(--text-secondary);
        margin-bottom: 8px;
      }

      footer {
        max-width: 720px;
        margin: 0 auto;
        padding: 32px 24px 64px;
        text-align: center;
        border-top: 1px solid var(--surface);
        color: var(--text-secondary);
        font-size: 14px;
      }
      footer a {
        color: var(--primary);
        text-decoration: none;
        font-family: var(--font-mono);
      }
      footer a:hover { text-decoration: underline; }
      .micro {
        font-size: 12px;
        color: var(--text-tertiary);
        margin-top: 8px;
      }

      @media (max-width: 480px) {
        .hero { padding: 64px 20px 32px; }
        .hero h1 { font-size: 40px; }
        .tagline { font-size: 16px; }
        .swatch-row { grid-template-columns: repeat(8, 1fr); }
      }
    </style>
  </body>
</html>
